{
  "name": "@midden/stamp",
  "version": "0.2.0",
  "description": "A lightweight Temporal-based time stamping utility for apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "validate": "pnpm run lint && pnpm run format:check && pnpm run test && pnpm run typecheck",
    "prepublishOnly": "pnpm run build"
  },
  "exports": {
    ".": "./dist/index.js",
    "./testing": "./dist/testing.js"
  },
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing.d.ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.5",
    "typescript-eslint": "^8.59.1"
  }
}
